# Client admin credentials (for current local admin gate)
VITE_ADMIN_USER=your-admin-user
VITE_ADMIN_PASSWORD=your-admin-password
VITE_ADMIN_JWT_SECRET=replace-with-a-long-random-secret

# Supabase project settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Phase 1 API server (non-OTP endpoints)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
API_PORT=8787
API_CORS_ORIGIN=http://localhost:5173
